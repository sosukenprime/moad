{
  "version": 3,
  "description": "MOAD locked design choices. These are NOT up for debate unless the owner explicitly asks to revisit.",
  "selections": {
    "headingFont":      { "id": "bebas",           "name": "Bebas Neue" },
    "headingCase":      { "id": "title",           "name": "Title Case" },
    "bodyFont":         { "id": "ibm-plex",        "name": "IBM Plex Sans" },
    "numberFont":       { "id": "ibm-plex-mono",   "name": "IBM Plex Mono" },
    "palette":          { "id": "command-deck",    "name": "Command Deck (dark navy + gold)" },
    "accent":           { "id": "keep",            "name": "Keep palette default (gold)" },
    "corners":          { "id": "subtle",          "name": "Subtle (6px radius)" },
    "cardStyle":        { "id": "glass",           "name": "Glass (translucent + backdrop blur)" },
    "density":          { "id": "balanced",        "name": "Balanced" },
    "background":       { "id": "mesh",            "name": "Gradient mesh (3-layer radial)" },
    "checkbox":         { "id": "hex",             "name": "Hexagon (clip-path polygon)" },
    "progressBar":      { "id": "gradient",        "name": "Smooth gradient with soft glow" },
    "iconStyle":        { "id": "line",            "name": "Thin line SVG icons" },
    "streak":           { "id": "fire",            "name": "Fire emoji + number + d suffix" },
    "completionEffect": { "id": "subtle",          "name": "Subtle strike + fade" },
    "levelup":          { "id": "REMOVED",         "name": "DEPRECATED in v3 — no XP/level system" },
    "terminology":      { "id": "mixed",           "name": "Loose military/operator vibe — Active Missions, Daily Protocol stay; The Lab, Loose Ends, The Ask, Comms are softer" },
    "greeting":         { "id": "name",            "name": "Time-based + name (Good morning, {name})" },
    "dateFormat":       { "id": "long",            "name": "Long (MONDAY, APRIL 21)" }
  },
  "colorTokens": {
    "bg":           "#0A0E1A",
    "bgDeep":       "#060912",
    "surfaceSolid": "#151A2E",
    "surface":      "rgba(255,255,255,0.04)",
    "border":       "rgba(255,255,255,0.08)",
    "borderStrong": "rgba(255,255,255,0.16)",
    "text":         "#EDEFF7",
    "textDim":      "#9AA0B8",
    "textMuted":    "#5C6380",
    "gold":         "#F5B942",
    "mint":         "#6EE7B7",
    "coral":        "#FF8A65",
    "rose":         "#F472B6",
    "cyan":         "#5EEAD4",
    "work":         "#60A5FA",
    "personal":     "#A78BFA",
    "creative":     "#F472B6",
    "daily":        "#6EE7B7"
  },
  "widgets": {
    "comms":     { "title": "Comms",          "color": "#5EEAD4", "token": "cyan",     "status": "active",      "notes": "One-shot capture: text + mic + send → API → Loose Ends. Uses VITE_ANTHROPIC_API_KEY." },
    "today":     { "title": "Today",          "color": "#F5B942", "token": "gold",     "status": "active",      "notes": "Daily focus task list" },
    "projects":  { "title": "Active Missions","color": "#60A5FA", "token": "work",     "status": "active",      "notes": "Multi-step long-running projects" },
    "deadlines": { "title": "Deadlines",      "color": "#FF8A65", "token": "coral",    "status": "active",      "notes": "Time-sensitive dates (bills, taxes)" },
    "habits":    { "title": "Daily Protocol", "color": "#6EE7B7", "token": "mint",     "status": "active",      "notes": "Daily habits with 🔥 streak badge" },
    "lab":       { "title": "The Lab",        "color": "#F472B6", "token": "creative", "status": "active",      "notes": "Creative tracker. 3 PERMANENT pinned slots at top (subtle pink-tinted bg). Below: list. Replaces v2 Side Ops." },
    "looseEnds": { "title": "Loose Ends",     "color": "#A78BFA", "token": "personal", "status": "active",      "notes": "UNIVERSAL CAPTURE INBOX. Items live here permanently, mirror to Today/Missions/Deadlines via boolean flags." },
    "theAsk":    { "title": "The Ask",        "color": "#5EEAD4", "token": "cyan",     "status": "placeholder", "notes": "Coming soon — future Michelle requests inbox. Just placeholder card in v3." }
  },
  "features": {
    "focusMode":     { "enabled": true,  "notes": "Hides all widgets except Today" },
    "haptic":        { "enabled": true,  "notes": "Mobile vibrate on task complete / habit tick" },
    "recurring":     { "enabled": true,  "notes": "Tasks only — daily/weekdays/weekly/monthly. NOT in Loose Ends." },
    "subtasks":      { "enabled": true,  "notes": "Tasks only. NOT in Loose Ends." },
    "editInline":    { "enabled": true,  "notes": "Pencil icon on task, click mission card" },
    "dragTasks":     { "enabled": true,  "notes": "Drag to reorder within Today" },
    "archive":       { "enabled": true,  "notes": "Missions can be archived" },
    "keyboard":      { "enabled": true,  "notes": "N / E / F / ? / Esc shortcuts. Skip / for now since Comms is placeholder." },
    "tags":          { "enabled": true,  "notes": "Custom free-text tags, purple chips, on Tasks and Missions" },
    "missionNotes":  { "enabled": true,  "notes": "Long-form notes field per mission" },
    "labPinning":    { "enabled": true,  "notes": "3 PERMANENT pinned slots at top of The Lab" },
    "xpSystem":      { "enabled": false, "notes": "REMOVED ENTIRELY IN V3" },
    "commsAI":       { "enabled": true,  "notes": "ACTIVE in v3 as one-shot capture. Conversational version is the upgrade path." },
    "michelleInbox": { "enabled": false, "notes": "DEFERRED — The Ask placeholder card only in v3" },
    "calendarView":  { "enabled": false, "notes": "DEFERRED" },
    "weeklyReview":  { "enabled": false, "notes": "DEFERRED" },
    "search":        { "enabled": false, "notes": "DEFERRED" },
    "stats":         { "enabled": false, "notes": "DEFERRED" }
  },
  "fontImportUrl": "https://fonts.googleapis.com/css2?family=Bebas+Neue&family=IBM+Plex+Mono:wght@400;500;700&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap",
  "defaultLayout": [
    { "id": "comms",     "size": "full" },
    { "id": "today",     "size": "full" },
    { "id": "projects",  "size": "half" },
    { "id": "deadlines", "size": "half" },
    { "id": "habits",    "size": "half" },
    { "id": "lab",       "size": "half" },
    { "id": "looseEnds", "size": "full" },
    { "id": "theAsk",    "size": "full" }
  ]
}
