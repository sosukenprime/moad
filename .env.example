# Anthropic API key — server-side only, no VITE_ prefix.
# Used by /api/comms.js (Vercel serverless function) to proxy Claude API calls.
# Set this in Vercel project settings → Environment Variables for production.
# For local dev, copy this file to .env.local and fill in your key.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
